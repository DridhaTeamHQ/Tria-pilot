# ============================================
# TRIA - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# ============================================
# Database & Supabase Configuration
# ============================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api
# Connection strings: Project Settings → Database → Connection string (URI)

# Direct database connection (non-pooler). Required for Prisma so User rows are created.
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"

# Direct URL (same as DATABASE_URL). Used for migrations. Do not use pooler URL here.
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"

# Supabase Project URL
# Format: https://[YOUR_PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"

# Supabase Anonymous Key (public, safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR_ANON_KEY]"

# Supabase Service Role Key (private, server-side only)
#  NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY="[YOUR_SERVICE_ROLE_KEY]"

# ============================================
# AI Services API Keys
# ============================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Used for: GPT-4o mini (prompt generation) and GPT-4o Vision (image analysis)
OPENAI_API_KEY="sk-proj-[YOUR_OPENAI_KEY]"

# Google Gemini API Key (single-key fallback)
# Get from: https://aistudio.google.com/app/apikey
# Used for: Image generation (Nano Banana / Gemini 3 Pro Image Preview)
GEMINI_API_KEY="[YOUR_GEMINI_KEY]"

# Google Gemini API Key Pool (RECOMMENDED for production)
# Comma-separated list of keys for round-robin load balancing.
# Each key has its own rate limit budget — more keys = more capacity.
# Free tier: ~2 RPM/key for Pro, ~10 RPM/key for Flash image models.
# IMPORTANT: include the GEMINI_API_KEY value here too if you want it in the pool.
# GEMINI_API_KEYS="key1,key2,key3,key4,key5"

# ============================================
# Ad Creative (Brand Ads / Gemini Image Gen)
# ============================================
# Chat model for building ad image-generation prompts from product + preset (default: gemini-2.5-flash)
# AD_PROMPT_MODEL="gemini-2.5-flash"
# Image model override for ad generation (default: uses GEMINI_IMAGE_MODEL)
# AD_IMAGE_MODEL="gemini-3-pro-image-preview"

# ============================================
# Optional AI Model Configuration
# ============================================

# Gemini Model Version (default: gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-1.5-pro, etc.
GEMINI_MODEL_VERSION="gemini-2.5-flash"

# Image Generation Model (default: gemini-3-pro-image-preview)
# Options:
#   - gemini-2.5-flash-image: Fast, 1024px, up to 3 images
#   - gemini-3-pro-image-preview: Professional, up to 4K, up to 14 images
GEMINI_IMAGE_MODEL="gemini-3-pro-image-preview"

# ============================================
# Try-On Pipeline Model Overrides (optional)
# ============================================
# GPT model for scene intelligence prompting (default: gpt-4o)
# TRYON_PROMPT_MODEL="gpt-4o"

# GPT model for forensic face/body anchor generation (default: gpt-4o)
# TRYON_FORENSIC_PROMPT_MODEL="gpt-4o"

# Face pixel compositing after generation (default: off to avoid ghost-face artifacts)
# Set to "true" only if you need post-generation face overlay; usually leave unset.
# TRYON_ENABLE_DETERMINISTIC_FACE_LOCK="true"

# ============================================
# Try-On Production Tuning (Phase 2 — concurrency + rate limiting)
# ============================================
# Enable the generation gate (daily cap + cooldown + kill switch).
# Auto-enabled when NODE_ENV=production. Set true here to test in dev.
# TRYON_LIMITER_ENABLED="true"

# Per-user daily generation cap (default: 10)
# MAX_TRYON_PER_DAY="10"

# Cooldown between consecutive generations from the same user, in seconds (default: 15)
# TRYON_COOLDOWN_SECONDS="15"

# Per-IP hourly request cap (default: 15) — backstop against abuse
# MAX_TRYON_PER_HOUR="15"

# Daily Gemini spend kill switch (USD) — once exceeded, all generations blocked (default: 15.0)
# TRYON_KILL_SWITCH_THRESHOLD_USD="15.0"

# Maximum jobs that can be sitting in the BullMQ queue waiting (default: 50)
# When exceeded, new requests are rejected with 503 / "queue full" instead of queued.
# TRYON_MAX_QUEUE_DEPTH="50"

# Worker concurrency — how many jobs the worker processes in parallel (default: 4)
# Tune to your Gemini key pool: 1 key=2, 3 keys=4, 5 keys=6, 10 keys=10
# TRYON_WORKER_CONCURRENCY="4"

# Gemini Pro image rate limiter (per-process Bottleneck). Defaults safe for 1 key.
# With 5 keys: maxConcurrent=3, minTime=1500
# With 10 keys: maxConcurrent=5, minTime=800
# GEMINI_PRO_MAX_CONCURRENT="1"
# GEMINI_PRO_MIN_TIME_MS="5000"

# Gemini Flash image rate limiter. Defaults safe for 1 key.
# GEMINI_FLASH_MAX_CONCURRENT="2"
# GEMINI_FLASH_MIN_TIME_MS="500"

# ============================================
# Try-On Queue: QStash (RECOMMENDED for Vercel deployments)
# ============================================
# QStash is Upstash's HTTP-based message queue. It's the Vercel-native
# replacement for BullMQ — no separate worker process needed. QStash POSTs
# each queued job to /api/tryon/process, which runs as a Vercel function.
#
# Setup:
#   1. Sign up at https://upstash.com/qstash
#   2. Console → QStash → copy Token, Current Signing Key, Next Signing Key
#   3. Set NEXT_PUBLIC_SITE_URL to your live domain (https://kiwikoo.com)
#   4. Add the three vars below
#
# Free tier: 500 messages/day. Paid: $1 per 1000 messages.
# QSTASH_TOKEN="qstash_token_here"
# QSTASH_CURRENT_SIGNING_KEY="sig_xxx"
# QSTASH_NEXT_SIGNING_KEY="sig_yyy"
# QSTASH_RETRIES="3"
# QSTASH_SIGNATURE_VERIFICATION="enabled"   # set to "disabled" only for local testing

# ============================================
# Try-On Queue: BullMQ + Redis (alternative — non-Vercel deployments)
# ============================================
# Use this on Railway/Render/Fly.io/VM hosts where you can run a long-lived worker.
# QStash takes priority if configured — this only activates as a fallback.
# Get URL: https://console.upstash.com → Create Redis database → copy Redis URL (rediss://...)
# TRYON_QUEUE_ENABLED="true"
# UPSTASH_REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379"

# ============================================
# Environment
# ============================================
# Use "production" when deploying (Vercel/Railway/etc. usually set this automatically).
# NODE_ENV="development"
# NODE_ENV="production"

# ============================================
# Email Delivery (SMTP)
# ============================================
# Used for password reset, confirmation, email-change approvals,
# and all other application emails.
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
# Set to "true" for implicit TLS (usually port 465).
SMTP_SECURE="false"
# Example: "Kiwikoo <no-reply@yourdomain.com>"
SMTP_FROM_EMAIL="Kiwikoo <no-reply@kiwikoo.com>"

# Optional fallback if SMTP is not configured
# RESEND_API_KEY="re_xxx"
# RESEND_FROM_EMAIL="Kiwikoo <no-reply@yourdomain.com>"

# ============================================
# Razorpay Billing
# ============================================
RAZORPAY_KEY_ID="rzp_test_..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

RAZORPAY_PLAN_INFLUENCER_STARTER_MONTHLY="plan_..."
RAZORPAY_PLAN_INFLUENCER_PRO_MONTHLY="plan_..."
RAZORPAY_PLAN_INFLUENCER_SCALE_MONTHLY="plan_..."

RAZORPAY_PLAN_BRAND_STARTER_MONTHLY="plan_..."
RAZORPAY_PLAN_BRAND_PRO_MONTHLY="plan_..."
RAZORPAY_PLAN_BRAND_SCALE_MONTHLY="plan_..."

# ============================================
# Face Swap Service (InsightFace)
# ============================================
# Optional external Python face-swap microservice.
# The main app can stay on Vercel, but this service should run separately
# (for example on Railway, Render, Fly.io, a VM, or another container host).
# Stage 4 remains Gemini-first and only calls this service as a fallback.
# Local development example:
# FACE_SWAP_SERVICE_URL="http://127.0.0.1:8765"
# Production example:
# FACE_SWAP_SERVICE_URL="https://your-face-swap-service.example.com"
# FACE_SWAP_TIMEOUT_MS="30000"
# Disable local auto-boot in environments where the service is remote:
# FACE_SWAP_AUTO_BOOT="false"
# Set to "true" to disable Stage 4 face restoration entirely:
# TRYON_DISABLE_FACE_RESTORE="true"
